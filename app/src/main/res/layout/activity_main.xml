<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mitra Medika"
            android:textColor="#1E293B"
            android:textSize="32sp"
            android:fontFamily="sans-serif-black"
            android:gravity="center"
            android:letterSpacing="-0.02"
            android:layout_marginTop="20dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pendaftaran Antrian Pasien"
            android:textColor="#64748B"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginBottom="40dp" />

        <EditText
            android:id="@+id/etNama"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:hint="Nama Lengkap"
            android:textColor="#334155"
            android:textColorHint="#94A3B8"
            android:background="@android:drawable/editbox_background"
            android:backgroundTint="#FFFFFF"
            android:paddingHorizontal="20dp"
            android:inputType="textPersonName"
            android:elevation="2dp"
            android:layout_marginBottom="18dp" />

        <EditText
            android:id="@+id/etKeluhan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Apa yang Anda rasakan hari ini?"
            android:textColor="#334155"
            android:textColorHint="#94A3B8"
            android:background="@android:drawable/editbox_background"
            android:backgroundTint="#FFFFFF"
            android:padding="20dp"
            android:gravity="top"
            android:elevation="2dp"
            android:minLines="5"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pilih Layanan Poli"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#475569"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="4dp"/>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="@android:drawable/editbox_background"
            android:backgroundTint="#FFFFFF"
            android:elevation="2dp"
            android:layout_marginBottom="32dp">
            <Spinner
                android:id="@+id/spinnerPoli"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingStart="12dp" />
        </FrameLayout>

        <Button
            android:id="@+id/btnAmbil"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="AMBIL NOMOR ANTRIAN"
            android:textAllCaps="true"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#0F172A"
            android:letterSpacing="0.05"
            app:cornerRadius="16dp"
            android:elevation="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@android:drawable/dialog_holo_light_frame"
            android:backgroundTint="#FFFFFF"
            android:padding="24dp"
            android:layout_marginTop="40dp"
            android:elevation="8dp">

            <TextView
                android:id="@+id/tvNomor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nomor Antrian: -"
                android:textColor="#0F172A"
                android:textSize="20sp"
                android:fontFamily="sans-serif-medium"
                android:gravity="center" />

            <View
                android:layout_width="60dp"
                android:layout_height="4dp"
                android:background="#E2E8F0"
                android:layout_gravity="center"
                android:layout_marginVertical="16dp" />

            <TextView
                android:id="@+id/tvCurrent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sedang dipanggil: -"
                android:textColor="#3B82F6"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center" />
        </LinearLayout>

        <Space
            android:layout_width="match_parent"
            android:layout_height="60dp" />

        <Button
            android:id="@+id/btnAdmin"
            android:layout_width="wrap_content"
            android:layout_gravity="center"
            android:layout_height="wrap_content"
            android:text="LOGIN ADMIN"
            android:textSize="12sp"
            android:textColor="#94A3B8"
            style="?android:attr/borderlessButtonStyle" />

    </LinearLayout>
</ScrollView>